---
title: MichałGórny.net
---

<!DOCTYPE html>
<html lang="{{ lang | default('en') }}">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ title }}</title>
		<script>(function(){var t=localStorage.getItem('theme');if(t==='dark'||t==='light')document.documentElement.setAttribute('data-theme',t);})();</script>
		<link rel="stylesheet" href="/styles/pico.indigo.min.css">
		<link rel="stylesheet" href="/styles/markfive.css">
		{% if css %}
			{% for sheet in css %}
				<link rel="stylesheet" href="{{ sheet }}">
			{% endfor %}
		{% endif %}
		<link rel="stylesheet" href="/styles/index.css">
	</head>
	<body>
		<nav class="top-bar" id="topBar">
			<div class="top-bar-content">
				<h1><a href="/" class="top-bar-title">MichałGórny.net</a></h1>
				<div class="top-bar-nav">
					<a
						href="mailto:zrchos@gmail.com"
						aria-label="{% if lang == 'pl' %}Kontakt{% else %}Contact{% endif %}"
						title="{% if lang == 'pl' %}Kontakt{% else %}Contact{% endif %}"
					>
						<i data-feather="mail"></i>
					</a>
					<a
						href="{{ sourceUrl | default('https://github.com/drastus/michalgorny.net') }}"
						aria-label="{% if lang == 'pl' %}Kod źródłowy{% else %}Source code{% endif %}"
						title="{% if lang == 'pl' %}Kod źródłowy{% else %}Source code{% endif %}"
					>
						<i data-feather="github"></i>
					</a>
					<a
						href="#"
						class="theme-toggle"
						id="themeToggle"
						aria-label="{% if lang == 'pl' %}Przełącz motyw{% else %}Toggle theme{% endif %}"
						title="{% if lang == 'pl' %}Tryb jasny{% else %}Light mode{% endif %}"
					>
						<i data-feather="sun" class="theme-icon"></i>
					</a>
				</div>
			</div>
		</nav>
		<div class="page-content"><div class="page-content-inner">{{ content | safe }}</div><div id="page-footer-root"></div></div>
		<script src="/js/feather.min.js"></script>
		<script>feather.replace();</script>
		<script src="/scripts/top-bar.js" type="module"></script>
		<script src="/scripts/notes.js" type="module"></script>
		{% if scripts %}
			{% for script in scripts %}
				<script src="{{ script }}" type="module"></script>
			{% endfor %}
		{% endif %}
	</body>
</html>
